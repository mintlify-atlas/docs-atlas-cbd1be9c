  "keyFeatures": [
    "Create and manage professional invoices",
    "Customer address book management",
    "Reusable invoice templates",
    "PDF generation and export",
    "Email delivery integration",
    "Multi-currency support (11 currencies)",
    "Invoice status tracking (draft, sent, paid, cancelled)",
    "Company profile and branding",
    "Payment details management",
    "Authentication with Google OAuth and credentials",
    "Dark mode support"
  ],
  "publicApiSurface": [
    "GET /api/invoices - Fetch all invoices",
    "POST /api/invoices - Create a new invoice",
    "GET /api/invoices/[id] - Get invoice by ID",
    "PATCH /api/invoices/[id] - Update invoice",
    "DELETE /api/invoices/[id] - Delete invoice",
    "POST /api/pdf - Generate PDF from invoice",
    "POST /api/email - Send invoice via email",
    "GET /api/templates - Fetch all templates",
    "POST /api/templates - Create a new template",
    "POST /api/auth/register - Register new user",
    "NextAuth endpoints - /api/auth/[...nextauth]"
  ]
